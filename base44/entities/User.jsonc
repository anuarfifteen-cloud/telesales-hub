{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "user"
      ]
    },
    "rotationNumber": {
      "type": "integer",
      "description": "Rotation number for the agent (1-11), shown in roster avatars"
    }
  },
  "required": [
    "role"
  ]
}