{
  "name": "EmployeeProfile",
  "type": "object",
  "properties": {
    "employeeName": {
      "type": "string",
      "description": "The full name of the employee (e.g., 'Kamaliah', 'Salwa')"
    },
    "shortName": {
      "type": "string",
      "description": "The short name for display (e.g., 'Kamaliah \ud83d\udd11')"
    },
    "rotationNumber": {
      "type": "number",
      "description": "The employee's rotation number"
    }
  },
  "required": [
    "employeeName"
  ]
}